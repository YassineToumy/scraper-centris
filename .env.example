# ============================================================
# MONGODB
# ============================================================
MONGODB_URI=mongodb://user:password@host:27017
MONGO_DB=centris
MONGO_COLLECTION=locations
MONGO_COLLECTION_CLEAN=locations_clean

# ============================================================
# SCRAPER SETTINGS
# ============================================================
# Search URL — Centris residential rentals (Quebec)
# Replace with your own filtered search URL from centris.ca
CENTRIS_SEARCH_URL=https://www.centris.ca/fr/propriete~a-louer?q=H4sIAAAAAAAACo2QMQ-CQAyF_8vNDKy6GRON0RgjhoU4VO4BFw8Oe6AhhP9uiQ6oi536Xr_XJu1Vab2aq1AF6sLuCl46DTFEuywzKbboXrL1WMPlTHXRRQXVkFwYKD-2scFDZHIWDeK02FP53pIZ24Dfw8zAah-Tbcd00r-MjRZ0SQ1yx51E7uNcrCO80agaQ1YNwRSOYK2p8lNX44Ovmi9wZ-7CLRg04aJbS4wV8ENTpf9lx2MHlgdN4PAPZjYpNZyHJz4eXrmCAQAA&sort=None&pageSize=20

# Seconds to sleep between full scrape cycles (86400 = 24h)
CYCLE_SLEEP=86400

# Max search result pages to browse (9999 = no limit)
MAX_PAGES=9999

# Max detail pages to scrape per cycle (999999 = no limit)
MAX_DETAILS=999999

# Skip listings already scraped in the last 24h (true/false)
SCRAPE_24H_SKIP=true

# ============================================================
# POSTGRESQL
# ============================================================
POSTGRES_DSN=postgresql://root:root@host:5432/firstMVP
PG_TABLE_CENTRIS=centris_listings
PG_ARCHIVE_CENTRIS=centris_archive

# ============================================================
# BACKBLAZE B2 (image storage)
# ============================================================
B2_KEY_ID=your_key_id
B2_APPLICATION_KEY=your_application_key
B2_ENDPOINT=https://s3.us-east-005.backblazeb2.com
B2_BUCKET=immo-world-bucket
